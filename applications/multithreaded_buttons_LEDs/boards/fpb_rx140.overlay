/*
 * FPB-RX140 board overlay for multithreaded_buttons_LEDs application.
 *
 * User-controllable GPIO peripherals on FPB-RX140:
 *   LED1 (green) : P20  - ioport2, pin 0, active-low
 *   LED2 (green) : P32  - ioport3, pin 2, active-low
 *   SW1 (user)   : P30  - ioport3, pin 0, active-low, pull-up  → IRQ0
 *
 * MTU1 is disabled here because the board DTS assigns P20 (LED1) to MTIOC1A
 * (PWM). Leaving it enabled causes MTU1 to reconfigure P20 away from GPIO.
 */

/ {
	leds {
		compatible = "gpio-leds";

		led1: led1 {
			gpios = <&ioport2 0 GPIO_ACTIVE_LOW>;
			label = "LED1";
		};

		led2: led2 {
			gpios = <&ioport3 2 GPIO_ACTIVE_LOW>;
			label = "LED2";
		};
	};

	buttons {
		compatible = "gpio-keys";

		sw1: button {
			label = "SW1";
			gpios = <&ioport3 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_KEY_0>;
		};

		sw2: button {
			label = "SW2";
			gpios = <&ioport3 1 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	aliases {
		led1 = &led1;
		led2 = &led2;
		sw1 = &sw1;
	};
};

/* Disable MTU1 so its pinctrl does not reconfigure P20 (LED1) away from GPIO. */
&mtu1 {
	status = "disabled";
};
